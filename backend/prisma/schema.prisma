generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VisitedCity {
  id              String   @id @default(cuid())
  cityName        String
  country         String
  latitude        Float
  longitude       Float
  boundaryGeojson Json?
  visitedAt       DateTime?
  notes           String?
  createdAt       DateTime @default(now())

  @@unique([cityName, country])
}